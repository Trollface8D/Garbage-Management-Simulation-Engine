generated graph edges (needed to specify as exhaustive extraction): https://gemini.google.com/share/a7778998c298
linking trash bin type: https://gemini.google.com/share/8d8b849daa2d

original;
{
    "extractmap_symbol": {
        "prompt": "from this map can you extract all notation that represent the symbol on the map out put as instructed markdown",
        "input": "map image"
    },
    "extractmap_text": {
        "prompt": "also put extracted data in Json format with label of node type ex. building, indoor buffer, outdoor buffer etc. and other information available and finally give me data sheet off the extracted data from this map can you extract all symbol that attach near the buffer label and add it as detail to this incomplete Json file",
        "input": "table showing trait and. data collected for each garbage buffer, symbol context",
        "note": "for accurate extraction it need to add only one picture as output at a time"
     },
     "tabular_extraction": {
        "prompt": "extract data from this table and put it in Json/csv format format",
        "input": "table image"
     },
     "edge_extraction": {
        "prompt": "from the map image can you exhaustively connect all possible traversal path, create list of edges for traversal graph with approximate cost from visible distance using node detail from json file as reference Export this detail for node connection as csv",
        "input": "extracted node data, map images"
     }
}
*/

{
    "runtime_prompts": {
        "extractmap_text_nodes_json_schema": "Use this JSON schema exactly:\n{\n  \"nodes\": [\n    {\"id\": \"string\", \"label\": \"string\", \"type\": \"string\", \"x\": 0.0, \"y\": 0.0, \"metadata\": {}}\n  ]\n}",
        "extractmap_text_support_joint_prompt": "Extract all bin/buffer node metadata by jointly analyzing the map image and support artifact image. Be exhaustive and preserve IDs exactly as they appear (e.g., L.1, TR.12).",
        "extractmap_text_support_fallback_prompt": "Extract all bin/buffer node metadata from the provided support artifact image. Be exhaustive and preserve IDs exactly as they appear (e.g., L.1, TR.12).",
        "extractmap_text_support_delta_prompt": "Extract any additional bin metadata missed previously from the support artifact image.",
        "extractmap_text_normalize_prompt": "Normalize the provided extracted content into JSON nodes.",
        "extractmap_text_normalize_context": "Produce JSON only with shape {\"nodes\": [...]} where each node includes id/label/type/metadata when available. Keep IDs exactly as seen in source text (e.g., L.1, TR.12).",
        "extractmap_text_support_delta_context": "Return concise text only. Focus on IDs and attributes not already extracted.",
        "tabular_extraction_output_hint": "Return CSV plain text only, with a header row.",
        "tabular_extraction_no_support_hint": "No support table image was uploaded; extract any visible tabular metadata from the map image.",
        "extractmap_symbol_output_hint": "Return a concise markdown table of symbols and notation. Process only the provided single map image.",
        "edge_extraction_json_schema": "Use this JSON schema exactly:\n{\n  \"edges\": [\n    {\"id\": \"string\", \"source\": \"string\", \"target\": \"string\", \"approximate_cost\": 0.0, \"label\": \"string\"}\n  ]\n}",
        "edge_extraction_csv_fallback_hint": "If JSON cannot be produced, return CSV with header: Source Node,Target Node,Approximate Cost"
    },
    "extractmap_symbol": {
        "task_description": "Extract map legend and notations.",
        "input_dependencies": ["map_image"],
        "prompt": "Analyze the provided map image and extract all map symbols along with their corresponding text notations. Output the results as a Markdown table with two columns: 'Symbol Description' and 'Notation'."
    },
    "extractmap_text": {
        "task_description": "Extract node metadata and update existing JSON.",
        "input_dependencies": ["map_image", "incomplete_json", "buffer_trait_table"],
        "note": "Process only one image at a time to ensure high extraction accuracy.",
        "prompt": "Analyze the provided map image and extract all text and symbols located near the 'buffer' labels. Cross-reference this with the provided buffer trait table. Update the provided incomplete JSON file with this new data. Categorize each item with a node type label (e.g., 'building', 'indoor_buffer', 'outdoor_buffer'). Output the final, completed data strictly in JSON format."
    },
    "tabular_extraction": {
        "task_description": "Convert visual tables into structured data.",
        "input_dependencies": ["table_image"],
        "prompt": "Extract all data from the provided table image. Output the extracted data in CSV format, ensuring all column headers and row alignments perfectly match the visual table."
    },
    "edge_extraction": {
        "task_description": "Build a traversal graph with estimated edge costs.",
        "input_dependencies": ["map_image", "extracted_node_json"],
        "prompt": "Using the provided map image and the reference node data from the JSON file, identify all possible traversal paths between nodes. Estimate the traversal cost (distance) based on visual scale. Create a comprehensive list of edges for a traversal graph. Export this data as a CSV file containing exactly three columns: 'Source Node', 'Target Node', and 'Approximate Cost'."
    }
}
