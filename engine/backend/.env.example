# Copy this file to .env and set your real key values.
# Google Gemini API key from https://aistudio.google.com/app/apikey
API_KEY=YOUR_GEMINI_API_KEY

# Optional fallback variable name used by the pipeline.
GOOGLE_API_KEY=

# Default Gemini model for backend features.
# map_extract uses this value when the UI model dropdown is left empty.
GEMINI_MODEL=gemini-2.5-flash

# Optional map_extract fallback configuration (advanced).
# Keep these empty for default behavior so the UI-selected model can switch at runtime.
# Global fallback for map_extract stages when UI does not specify a model.
GEMINI_MAP_EXTRACT_MODEL=
# Per-stage model overrides (fall back to GEMINI_MAP_EXTRACT_MODEL, then GEMINI_MODEL):
GEMINI_MAP_EXTRACT_MODEL_SYMBOL=
GEMINI_MAP_EXTRACT_MODEL_TEXT=
GEMINI_MAP_EXTRACT_MODEL_TABULAR=
GEMINI_MAP_EXTRACT_MODEL_EDGE=

# Token usage / generation guardrails
# Keep output concise and avoid excessive token spend.
GEMINI_THINKING_BUDGET=4096
# Backend does not set max_output_tokens explicitly; provider default is used.

# Optional rough cost estimate shown in UI (bottom-right).
# Leave as 0 to disable cost estimate while still showing token usage.
MAP_EXTRACT_INPUT_USD_PER_1M_TOKENS=0
MAP_EXTRACT_OUTPUT_USD_PER_1M_TOKENS=0
