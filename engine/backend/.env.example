# Copy this file to .env and set your real key values.
# Google Gemini API key from https://aistudio.google.com/app/apikey
API_KEY=YOUR_GEMINI_API_KEY

# Optional fallback variable name used by the pipeline.
GOOGLE_API_KEY=

# Default Gemini model for backend features (including map_extract if stage overrides are not set).
GEMINI_MODEL=gemini-2.5-flash

# map_extract model configuration
# Global override for all map_extract stages.
GEMINI_MAP_EXTRACT_MODEL=
# Per-stage model overrides (fall back to GEMINI_MAP_EXTRACT_MODEL, then GEMINI_MODEL):
GEMINI_MAP_EXTRACT_MODEL_SYMBOL=
GEMINI_MAP_EXTRACT_MODEL_TEXT=
GEMINI_MAP_EXTRACT_MODEL_TABULAR=
GEMINI_MAP_EXTRACT_MODEL_EDGE=
