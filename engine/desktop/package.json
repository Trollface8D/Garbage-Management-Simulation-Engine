{
  "name": "gms-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "description": "Desktop shell for Garbage Management Simulation Engine",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac dmg zip"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.gms.desktop",
    "productName": "Garbage Management Simulation Engine",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "package.json",
      "resources/**/*",
      "assets/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    }
  }
}
